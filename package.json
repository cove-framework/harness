{
  "name": "@cove-framework/cove",
  "type": "module",
  "version": "0.1.0",
  "description": "Cove — a Convex-native agent harness (rewrite of the flue framework)",
  "license": "MIT",
  "homepage": "https://github.com/cove-framework/cove#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cove-framework/cove.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.18"
  },
  "files": [
    "dist",
    "bin",
    "convex",
    "src/runtime",
    "README.md",
    "!**/__tests__/**",
    "!**/*.test.ts",
    "!**/*.map",
    "!convex/_generated/**",
    "!convex/_cove/**"
  ],
  "exports": {
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "cove": "./bin/cove.mjs"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup",
    "convex": "convex dev",
    "deploy": "convex deploy",
    "cove": "tsx bin/cove.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build && npm run typecheck && npm test"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.0",
    "@ai-sdk/gateway": "^1.0.41",
    "@ai-sdk/google": "^2.0.76",
    "@ai-sdk/openai": "^2.0.0",
    "@convex-dev/workflow": "^0.3.12",
    "@convex-dev/workpool": "^0.4.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.0",
    "@upstash/box": "^0.4.4",
    "@valibot/to-json-schema": "^1.0.0",
    "ai": "^5.0.0",
    "convex": "^1.39.0",
    "convex-helpers": "^0.1.118",
    "jose": "^6.2.3",
    "js-yaml": "^4.2.0",
    "valibot": "^1.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ai-sdk/provider-utils": "^3.0.0",
    "@edge-runtime/vm": "^5.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "convex-test": "^0.0.53",
    "happy-dom": "^20.10.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6",
    "vitest": "^4.1.5"
  }
}
