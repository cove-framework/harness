# ─────────────────────────────────────────────────────────────────────────────
# Group-4 (Convex → AWS migration) environment template
# Copy to `.env` and fill in. `.env` is gitignored.
# Decisions in effect: Bedrock KEYLESS model path · deploy for real as we go.
# Var names match what the code actually reads (process.env.*) — do not rename.
# ─────────────────────────────────────────────────────────────────────────────

# ── 1. AWS deploy access ─────────────────────────── REQUIRED NOW (G4.1 deploy)
# Use a SANDBOX account, not prod. Pick ONE auth style:
#   (a) named profile / SSO — preferred; run `aws sso login --profile <name>` yourself
AWS_PROFILE=
#   (b) OR static keys (leave AWS_PROFILE blank if you use these)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Target account + region (CDK bootstrap/deploy). Bedrock model access must be
# enabled in THIS region (console toggle — keyless still needs granted access).
AWS_REGION=us-east-1
CDK_DEFAULT_ACCOUNT=
CDK_DEFAULT_REGION=us-east-1

# ── 2. Model provider: BEDROCK KEYLESS ───────────── no key — role IS the cred
# Lambda execution role authorizes Bedrock; gateway.ts recognizes the AWS chain
# (AWS_ROLE_ARN / AWS_WEB_IDENTITY_TOKEN_FILE) at runtime — nothing to set here.
# Leave the alternative provider keys BLANK unless you switch off Bedrock:
# AI_GATEWAY_API_KEY=          # only if you choose the AI Gateway path instead
# ANTHROPIC_API_KEY=           # only for the direct-provider path
# OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=

# ── 3. Tool sandbox ──────────────── self-hosted EC2 + Docker (D-AWS-15)
# No third-party token: the sandbox is a single EC2 host running Docker,
# provisioned by sandbox-stack.ts (G4.1) and driven via SSM Run Command.
# These are CDK context / Lambda env, not secrets — set after G4.1 deploys.
# SANDBOX_INSTANCE_ID=        # EC2 instance id output by sandbox-stack
# SANDBOX_IMAGE=              # base Docker image for per-run containers

# ── 4. Channels ──────────────────────────────────── DEFERRED to G4.7
# Only fill the platforms you actually wire up. Webhook secrets verify inbound
# signatures inside the channels Lambda (closed-by-default authorizer can't see
# the raw body). Bot tokens are for outbound reply.
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=

GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=

LINEAR_WEBHOOK_SECRET=
LINEAR_API_KEY=

NOTION_WEBHOOK_SECRET=
NOTION_VERIFICATION_TOKEN=
NOTION_API_KEY=

TELEGRAM_SECRET_TOKEN=
TELEGRAM_BOT_TOKEN=

TEAMS_APP_ID=
TEAMS_BOT_TOKEN=

GOOGLE_CHAT_PROJECT_NUMBER=
GOOGLE_CHAT_BOT_TOKEN=
